# === OpenAI / LLM Configuration ===
LLM_MODEL=xiaomi/mimo-v2-pro:free
LLM_API_KEY=sk-example
LLM_BASE_URL=https://www.openai.com/v1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT=60

# === Telegram Bot Configuration ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_TOKEN_LOG=your_log_bot_token_here
TELEGRAM_USER_IDS=123456789,987654321
TELEGRAM_LOG_LEVEL=info
TELEGRAM_MESSAGE_RATE_LIMIT=10
TELEGRAM_ENABLE_NOTIFICATIONS=true

# === Agent Configuration ===
AGENT_MAX_CONCURRENT_AGENTS=10
AGENT_TASK_TIMEOUT_DEFAULT=3600
AGENT_MEMORY_CONTEXT_LIMIT=8000
AGENT_MAX_RETRIES=3
AGENT_RETRY_BACKOFF_FACTOR=2
AGENT_ENABLE_REFLECTION=true
AGENT_STREAMING_ENABLED=false

# === Shell Command Executor Configuration ===
COMMAND_EXECUTOR_TIMEOUT_DEFAULT=300
COMMAND_EXECUTOR_MAX_OUTPUT_SIZE=10485760
COMMAND_EXECUTOR_MEMORY_LIMIT=512
COMMAND_EXECUTOR_CPU_SHARES=1024
COMMAND_EXECUTOR_MAX_CONCURRENT=5
COMMAND_EXECUTOR_ENABLE_SANDBOX=true
COMMAND_EXECUTOR_DANGEROUS_COMMANDS_BLACKLIST=rm -rf /,: () { : | : & };:
COMMAND_EXECUTOR_WORKING_DIR=/tmp/agent_workdir

# === Storage & Persistence ===
DATABASE_URL=sqlite:///./agent_tasks.db
REDIS_URL=redis://localhost:6379/0
STORAGE_LOGS_DIR=/var/log/autogen-agent
STORAGE_TEMP_DIR=/tmp/autogen-agent

# === System Configuration ===
LOG_LEVEL=info
DEBUG_MODE=false
MAX_RUN_ITERATIONS=50
HEARTBEAT_INTERVAL=30
TASK_PERSISTENCE_ENABLED=true

# === Docker/Container Configuration ===
CONTAINER_MEMORY_LIMIT=1g
CONTAINER_CPU_LIMIT=1.0
CONTAINER_NETWORK_ISOLATED=false

# === Advanced Options ===
ENABLE_HUMAN_IN_LOOP=true
ENABLE_TASK_BREAKDOWN_VISUALIZATION=false
API_PORT=8000
API_HOST=0.0.0.0
