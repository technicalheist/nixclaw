# ============================================================
# NixClaw Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ------------------------------------------------------------
# LLM Provider Selection
# Options: openai | anthropic | gemini | vertex | qwen
# ------------------------------------------------------------
PROVIDER=openai

# ------------------------------------------------------------
# OpenAI / OpenAI-compatible (Ollama, vLLM, custom endpoints)
# Used when PROVIDER=openai
# ------------------------------------------------------------
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ------------------------------------------------------------
# Anthropic
# Used when PROVIDER=anthropic
# ------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-opus-20240229

# ------------------------------------------------------------
# Google Gemini
# Used when PROVIDER=gemini
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.5-flash

# ------------------------------------------------------------
# Vertex AI
# Used when PROVIDER=vertex
# ------------------------------------------------------------
VERTEX_API_KEY=your_vertex_api_key_here
VERTEX_BASE_URL=https://aiplatform.googleapis.com/v1
VERTEX_MODEL=gemini-2.5-flash-lite

# ------------------------------------------------------------
# Qwen (uses email + password authentication, no API key)
# Used when PROVIDER=qwen
# ------------------------------------------------------------
QWEN_EMAIL=your_email_here
QWEN_PASSWORD=your_password_here
QWEN_MODEL=qwen3.5-plus

# ------------------------------------------------------------
# Optional: Generic LLM overrides (apply on top of provider defaults)
# Leave blank to use provider-specific values above.
# Useful for custom/self-hosted deployments regardless of provider.
# ------------------------------------------------------------
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT=60

# ------------------------------------------------------------
# Telegram Bot Configuration
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_TOKEN_LOG=your_log_bot_token_here
TELEGRAM_USER_IDS=123456789,987654321
TELEGRAM_LOG_LEVEL=info
TELEGRAM_MESSAGE_RATE_LIMIT=10
TELEGRAM_ENABLE_NOTIFICATIONS=true

# ------------------------------------------------------------
# Agent Configuration
# ------------------------------------------------------------
AGENT_MAX_CONCURRENT_AGENTS=10
AGENT_TASK_TIMEOUT_DEFAULT=3600
AGENT_MEMORY_CONTEXT_LIMIT=8000
AGENT_MAX_RETRIES=3
AGENT_RETRY_BACKOFF_FACTOR=2
AGENT_ENABLE_REFLECTION=true
AGENT_STREAMING_ENABLED=false

# ------------------------------------------------------------
# Shell Command Executor Configuration
# ------------------------------------------------------------
COMMAND_EXECUTOR_TIMEOUT_DEFAULT=300
COMMAND_EXECUTOR_MAX_OUTPUT_SIZE=10485760
COMMAND_EXECUTOR_MEMORY_LIMIT=512
COMMAND_EXECUTOR_CPU_SHARES=1024
COMMAND_EXECUTOR_MAX_CONCURRENT=5
COMMAND_EXECUTOR_ENABLE_SANDBOX=true
COMMAND_EXECUTOR_DANGEROUS_COMMANDS_BLACKLIST=rm -rf /,: () { : | : & };:
COMMAND_EXECUTOR_WORKING_DIR=/tmp/agent_workdir

# ------------------------------------------------------------
# Storage & Persistence
# ------------------------------------------------------------
DATABASE_URL=sqlite:///./agent_tasks.db
REDIS_URL=redis://localhost:6379/0
STORAGE_LOGS_DIR=/var/log/nixagent
STORAGE_TEMP_DIR=/tmp/nixagent

# ------------------------------------------------------------
# System Configuration
# ------------------------------------------------------------
LOG_LEVEL=info
DEBUG_MODE=false
MAX_RUN_ITERATIONS=50
HEARTBEAT_INTERVAL=30
TASK_PERSISTENCE_ENABLED=true

# ------------------------------------------------------------
# Docker / Container Configuration
# ------------------------------------------------------------
CONTAINER_MEMORY_LIMIT=1g
CONTAINER_CPU_LIMIT=1.0
CONTAINER_NETWORK_ISOLATED=false

# ------------------------------------------------------------
# Advanced Options
# ------------------------------------------------------------
ENABLE_HUMAN_IN_LOOP=true
ENABLE_TASK_BREAKDOWN_VISUALIZATION=false
API_PORT=8000
API_HOST=0.0.0.0
